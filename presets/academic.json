{
    "label": "学术论文",
    "description": "适合学术论文/毕业论文排版",
    "rules": {
        "font": {
            "family": "Times New Roman",
            "size_pt": 12.0,
            "color_hex": "#000000",
            "bold_default": false,
            "italic_default": false
        },
        "paragraph": {
            "alignment": "justify",
            "line_spacing": 1.5,
            "first_line_indent_cm": 1.27,
            "space_before_pt": 0,
            "space_after_pt": 6
        },
        "page": {
            "size": "A4",
            "orientation": "portrait",
            "margins_cm": {
                "top_cm": 2.54,
                "bottom_cm": 2.54,
                "left_cm": 3.17,
                "right_cm": 3.17
            }
        },
        "headings": {
            "1": { "font_size_pt": 22, "bold": true, "italic": false, "alignment": "center" },
            "2": { "font_size_pt": 16, "bold": true, "italic": false },
            "3": { "font_size_pt": 14, "bold": true, "italic": false },
            "4": { "font_size_pt": 12, "bold": true, "italic": false },
            "5": { "font_size_pt": 12, "bold": false, "italic": true },
            "6": { "font_size_pt": 12, "bold": false, "italic": true }
        },
        "header": {
            "enabled": false,
            "text": null,
            "show_page_numbers": false
        },
        "footer": {
            "enabled": true,
            "text": null,
            "show_page_numbers": true
        },
        "images": {
            "max_width_cm": 14.0,
            "alignment": "center",
            "add_captions": true
        }
    }
}
